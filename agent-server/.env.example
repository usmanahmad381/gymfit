# OpenAI API key (used for ingestion, embeddings, the agent, and File Search)
OPENAI_API_KEY=sk-...

# Printed by `python ingest.py` after the vector store is created
GYMFIT_VECTOR_STORE_ID=vs_...

# Comma-separated browser origins allowed to call this server
CHATKIT_ALLOWED_ORIGINS=http://localhost:3000
